local function isElementVisible(element)
    if not element then return false end
    local ok, addr = pcall(function() return element.Address end)
    if not ok or not addr or addr == 0 then return false end
    local ok2, result = pcall(function() return memory_read("byte", addr + VISIBLE_OFFSET) == 1 end)
    return ok2 and result or false
end

local function magnitude(v)
    return mathSqrt(v.X * v.X + v.Y * v.Y + v.Z * v.Z)
end

local function _horizontalDistance(a, b)
    local dx = a.X - b.X
    local dz = a.Z - b.Z
    return mathSqrt(dx * dx + dz * dz)
end

local function isValidPart(part)
    if not part or not part.Parent then return false end
    local ok, pos = pcall(function() return part.Position end)
    if not ok or not pos then return false end
    if pos.X ~= pos.X then return false end
    return not (pos.X == 0 and pos.Y == 0 and pos.Z == 0)
end

local function _formatTime(seconds)
    return mathFloor(seconds / 60) .. "m " .. mathFloor(seconds % 60) .. "s"
end

