-- #region Refill & Blade Logic
local function AreBladesFullyBroken()
    local char = LocalPlayer.Character
    local rig = char and char:FindFirstChild("Rig_" .. LocalPlayer.Name)
    if not rig then return false end
    local rh, lh = rig:FindFirstChild("RightHand"), rig:FindFirstChild("LeftHand")
    local rb, lb = rh and rh:FindFirstChild("Blade_1"), lh and lh:FindFirstChild("Blade_1")
    if not rb or not lb then return false end

    local ok, broken = pcall(function()
        local one = memory_read("float", rb.Address + 240)
        local two = memory_read("float", lb.Address + 240)
        return (one >= 0.9 and two >= 0.9)
    end)
    return ok and broken
end

local function DoINeedToRefill()
    if not DownMiddlePartUi then return false end
    local sets = GetPath(DownMiddlePartUi, "Blades", "Sets")
    local gas = GetPath(DownMiddlePartUi, "Gas", "Percentage")
    local bladesVal = sets and tonumber(sets.Text:match("%d+")) or 0
    local gasVal = gas and tonumber(gas.Text:match("%d+")) or 0
    return (bladesVal == 0 or gasVal == 0)
end

local function HandleAllReloads()
    if not AreBladesFullyBroken() then return end
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if DoINeedToRefill() then
        while autofarmActive and DoINeedToRefill() do
            if GasTank then
                local PartAddr = memory_read("uintptr_t", GasTank.Address + PrimaryPartOffset)
                local Prim = memory_read("uintptr_t", PartAddr + BaseToPrimitiveOffset)
                local x = memory_read("float", Prim + PrimitivePositionOffset)
                local y = memory_read("float", Prim + PrimitivePositionOffset + 4)
                local z = memory_read("float", Prim + PrimitivePositionOffset + 8)

                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.CFrame = CFrame.new(x, y, z)
                task.wait(0.3)
                keypress(0x52) task.wait(2) keyrelease(0x52)
            end
            task.wait(1)
        end
    else
        if ReloadingBlades or (os.clock() - LastReloadingTime < 3) then return end
        ReloadingBlades = true
        LastReloadingTime = os.clock()
        task.spawn(function()
            if isrbxactive() then
                keypress(0x52) task.wait(2) keyrelease(0x52) task.wait(0.5)
            end
            ReloadingBlades = false
        end)
    end
end
-- #endregion

-- #region Main Loop
local function autofarmLoop()
    while autofarmActive do
        pcall(function()
            local now = os.clock()
            
            -- 1. Maintenance & Survival
            -- Uses the memory-reading HandleAllReloads from your second snippet
            HandleAllReloads()

            -- 2. Immediate Game-Over Check
            -- Uses the memory-reading isRetryVisible check
            if isRetryVisible() then
                print("Game end detected via memory. Retrying...")
                PressRetry()
                task.wait(1) 
                return -- Restart the loop to handle teleport/reset
            end

            -- 3. Target Acquisition
            local titan, nape = getBestTitan()
            
            -- 4. Handling "No Titans" (Wait, Raid Completion, or Retry)
            if not titan or not nape then
                if not isInLoadingPeriod() then
                    if not noTitansTime then noTitansTime = now end
                    
                    if raidDetected then
                        -- Logic for Raid Rewards (Chests)
                        if isRaidFullyComplete() then
                            if now - noTitansTime >= 1 then
                                m1Active = false
                                task.wait(2)
                                -- Note: Ensure these click functions match your UI paths
                                clickChest("Free")
                                task.wait(7)
                                clickChest("Premium")
                                task.wait(7)
                                clickChestFinish()
                                task.wait(2)
                                PressRetry() 
                                noTitansTime = nil
                            end
                        else
                            -- Wait for next wave spawn
                            if now - noTitansTime >= 2 then
                                if isSkipVisible() then print("Wave skip available...") end
                                noTitansTime = now
                            end
                        end
                    else
                        -- Standard Retry (Map cleared or bugged)
                        if now - noTitansTime >= 0.5 then
                            m1Active = false
                            print("No targets found. Executing retry sequence.")
                            PressRetry()
                            noTitansTime = nil
                        end
                    end
                end
                task.wait(0.5)
                return
            end

            -- 5. Combat Initialization
            noTitansTime = nil
            local isAttack = titan.Name == "Attack_Titan"
            currentTargetTitan = titan
            currentTargetNape = nape
            
            if not cameraLocked then lockCamera() end
            local killsBefore = getKillCount()
            m1Active = true
            
            -- 6. Active Combat Loop
            while autofarmActive do
                -- Break if state changes or target is lost
                if not isrbxactive() or isTitanDead(titan) then break end
                if AreBladesFullyBroken() then break end 
                if isRetryVisible() then break end -- Break combat if rewards screen pops up

                -- If kill count increased, we consider the target dead
                if getKillCount() > killsBefore then
                    killedTitans[titan] = os.clock()
                    break
                end
                
                -- Execution logic
                tpAboveTitan(titan)
                bringNapeToPlayer(nape)
                
                if isAttack then
                    bringAttackTitanParts(titan)
                else
                    bringAllNearbyNapes(nape, titan)
                end

                if cameraLocked and isrbxactive() then
                    aimAtTitan(titan)
                end
                
                task.wait() -- Maintain standard refresh rate
            end

            -- Cleanup after combat
            m1Active = false
            currentTargetTitan = nil
            currentTargetNape = nil
        end)
        task.wait(0.05) -- Small delay to prevent CPU spiking
    end
end
