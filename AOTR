-- #region Offset Management
local function GetOffsets()
    local ok, res = pcall(function()
        return game:HttpGet("https://imtheo.lol/Offsets/Offsets.json")
    end)
    if not ok or not res then return {} end
    local success, decoded = pcall(function() return HttpService:JSONDecode(res) end)
    return success and decoded.Offsets or {}
end

local Offsets = GetOffsets()
local PrimaryPartOffset = Offsets.Model and Offsets.Model.PrimaryPart
local BaseToPrimitiveOffset = Offsets.BasePart and Offsets.BasePart.Primitive
local PrimitivePositionOffset = Offsets.Primitive and Offsets.Primitive.Position
local VisibleOffset = Offsets.GuiObject and Offsets.GuiObject.Visible

-- Path Helper
local function GetPath(root, ...)
    local current = root
    for _, name in ipairs({...}) do
        if not current then return nil end
        current = current:FindFirstChild(name)
    end
    return current
end

local DownMiddlePartUi = GetPath(PlayerGui, "Interface", "HUD", "Main", "Top", "7")
-- #endregion

-- #region UI & Retry Logic
local function IsObjectVisible(object)
    if not object or not object.Address then return false end
    local ok, value = pcall(function()
        return memory_read("byte", object.Address + VisibleOffset)
    end)
    return ok and value == 1
end

local function isRetryVisible()
    local Path = GetPath(PlayerGui, "Interface", "Rewards")
    return IsObjectVisible(Path)
end

local function PressRetry()
  if not isRetryVisible() then return end
  task.wait(2) -- Doubled from 1
  keypress(0xDE); task.wait(0.3); keyrelease(0xDE); task.wait(1.0) -- Doubled hold (0.15 -> 0.3) and gap (0.5 -> 1.0)
  keypress(0xDC); task.wait(0.3); keyrelease(0xDC); task.wait(1.0) 
