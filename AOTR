local function getBestTitan()
    local attackTitan = getAttackTitan()
    if attackTitan then
        currentMissionType = "Raid"
        raidDetected = true
        if isAttackTitanRoaring() then return nil, nil end
        local nape = getNapeFast(attackTitan) or getNape(attackTitan)
        if nape and isValidPart(nape) then return attackTitan, nape end
        return nil, nil
    end
    local useStallSort = currentMissionType == "Stall"
    local children = titansFolder and titansFolder:GetChildren() or {}
    if not useStallSort then
        for i = 1, #children do
            local ok, t = pcall(function() return children[i]:GetAttribute("Type") end)
            if ok and (t == "Colossal" or t == "Stall") then
                useStallSort = true
                break
            end
        end
    end
    local allValid = {}
    for i = 1, #children do
        local titan = children[i]
        if not isTitanDead(titan) then
            local nape = getNapeFast(titan)
            if nape and isValidPart(nape) then
                local dist = getDistanceToTitan(titan)
                allValid[#allValid + 1] = { titan = titan, nape = nape, distance = dist }
            end
        end
    end
    if #allValid == 0 then
        for i = 1, #children do
            local titan = children[i]
            if not isTitanDead(titan) then
                task.wait(0.02)
                local nape = getNape(titan)
                if nape and isValidPart(nape) then
                    local dist = getDistanceToTitan(titan)
                    allValid[#allValid + 1] = { titan = titan, nape = nape, distance = dist }
                end
            end
        end
    end
    if #allValid == 0 then return nil, nil end
    table.sort(allValid, function(a, b) return a.distance < b.distance end)
    return allValid[1].titan, allValid[1].nape
end
