local function bringAttackTitanParts(titan)
    if not titan or not titan.Parent then return end
    local hrp = getHRP()
    if not hrp then return end
    local playerPos = hrp.Position
    local hb = titan:FindFirstChild("Hitboxes")
    if not hb then return end
    local hit = hb:FindFirstChild("Hit")
    if not hit then return end
    local partNames = {"Nape", "LeftLeg", "RightLeg", "LeftArm", "RightArm", "Eyes"}
    for i = 1, 6 do
        local part = hit:FindFirstChild(partNames[i])
        if part and part.Parent then
            pcall(function()
                part.Position = playerPos + Vector3.new(0, 2, 0)
                part.Size = Vector3.new(15, 15, 15)
            end)
        end
    end
end

