local function tpAboveTitan(titan)
    local hrp = getHRP()
    if not hrp then return end
    local bobHeight = getTitanBobHeight(titan)
    local bobOffset = mathSin(osClock() * BOB_SPEED * 3.14159 * 2) * BOB_AMPLITUDE
    local targetPos = nil

    if currentMissionType == "Stall" then
        local head = getTitanHead(titan)
        if head then
            local ok, pos = pcall(function() return head.Position end)
            if ok then targetPos = pos end
        end
    end

    if not targetPos then
        local thrp = getTitanHRP(titan)
        if not thrp then return end
        local ok, pos = pcall(function() return thrp.Position end)
        if not ok then return end
        targetPos = pos
    end

    hrp.Position = Vector3.new(targetPos.X, targetPos.Y + bobHeight + bobOffset, targetPos.Z)
