local function bringAllNearbyNapes(mainNape, mainTitan)
    if currentMissionType == "Raid" then return end
    if not mainNape or not isValidPart(mainNape) then return end
    local hrp = getHRP()
    if not hrp then return end
    local ok, playerPos = pcall(function() return hrp.Position end)
    if not ok then return end
    local mainTHRP = getTitanHRP(mainTitan)
    if not mainTHRP then return end
    local ok2, mainPos = pcall(function() return mainTHRP.Position end)
    if not ok2 then return end
    local children = titansFolder and titansFolder:GetChildren() or {}
    for i = 1, #children do
        local titan = children[i]
        if titan ~= mainTitan and not isTitanDead(titan) then
            local nape = getNapeFast(titan)
            if nape and isValidPart(nape) then
                local thrp = getTitanHRP(titan)
                if thrp then
                    local ok3, dist = pcall(function() return magnitude(thrp.Position - mainPos) end)
                    if ok3 and dist <= NEARBY_NAPE_RADIUS then
                        pcall(function()
                            nape.Position = playerPos + Vector3.new(0, 2, 0)
                            nape.Size = Vector3.new(15, 15, 15)
                        end)
                    end
                end
            end
        end
    end
