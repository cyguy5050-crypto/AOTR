local function aimAtPosition(targetPos)
  --[[
    if not targetPos then return false end
    local screenPos = worldToScreen(targetPos)
    if not screenPos then return false end
    local vs = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize
    if not vs then return false end
    local deltaX = screenPos.X - vs.X / 2
    local deltaY = screenPos.Y - vs.Y / 2
    if mathAbs(deltaX) < 5 and mathAbs(deltaY) < 5 then return true end
    mousemoverel(deltaX * 0.5, deltaY * 0.5)
    ]]
    return false
end

local function aimAtTitan(titan)
    if not titan or isTitanDead(titan) then return end
    local head = titan:FindFirstChild("Head")
    if not head or not head.Parent then return end
    local hrp = getHRP()
    if not hrp then return end
    local ok, headPos, playerPos = pcall(function() return head.Position, hrp.Position end)
    if not ok then return end
    local dirX = headPos.X - playerPos.X
    local dirZ = headPos.Z - playerPos.Z
    local dist = mathSqrt(dirX * dirX + dirZ * dirZ)
    if dist > 0 then dirX = dirX / dist; dirZ = dirZ / dist else dirX = 0; dirZ = 1 end
    aimAtPosition(Vector3.new(headPos.X + dirX * 150, headPos.Y, headPos.Z + dirZ * 150))
end

local function clickElement(element)
    if not element then return false end
