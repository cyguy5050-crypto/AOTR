-- Reuse edges table to avoid reallocating every frame
local BOX_EDGES = {
    { 1, 2 }, { 1, 3 }, { 2, 4 }, { 3, 4 },
    { 5, 6 }, { 5, 7 }, { 6, 8 }, { 7, 8 },
    { 1, 5 }, { 2, 6 }, { 3, 7 }, { 4, 8 }
}

local function log(message, prefix)
    prefix = prefix or "DEBUG"
    print("[" .. prefix .. "] " .. tostring(message))
end

local function debugNotify(message, title)
    if UI.GetValue("debug_mode") then
        notify(message, title or "Debug", 1)
    end
end

local function worldToScreen(worldPos)
    if not worldPos then return nil end
    local success, screenPos, isOnScreen = pcall(function()
        return WorldToScreen_fn(worldPos)
    end)
    if not success or not screenPos or not isOnScreen then return nil end
    return screenPos
end

local function getCorners(center, size)
    if not center or not size then return {} end
    local sx, sy, sz = size.X / 2, size.Y / 2, size.Z / 2
    return {
        Vector3.new(center.X - sx, center.Y - sy, center.Z - sz),
        Vector3.new(center.X + sx, center.Y - sy, center.Z - sz),
        Vector3.new(center.X - sx, center.Y + sy, center.Z - sz),
        Vector3.new(center.X + sx, center.Y + sy, center.Z - sz),
        Vector3.new(center.X - sx, center.Y - sy, center.Z + sz),
        Vector3.new(center.X + sx, center.Y - sy, center.Z + sz),
        Vector3.new(center.X - sx, center.Y + sy, center.Z + sz),
        Vector3.new(center.X + sx, center.Y + sy, center.Z + sz),
    }
end

local function getNape(titan)
    if not titan or not titan.Parent then return nil end

    -- return cached nape when valid
    local cached = napeCache[titan]
    if cached and cached.Parent and cached:IsA("BasePart") then
        return cached
    end

    local found = nil
    pcall(function()
        local hb = titan:FindFirstChild("Hitboxes")
        if hb and hb.Parent then
            local hit = hb:FindFirstChild("Hit")
            if hit and hit.Parent then
                local n = hit:FindFirstChild("Nape") or hit:FindFirstChild("nape")
                if n and n.Parent and n:IsA("BasePart") then
                    found = n
                    return
                end
            end
        end

        -- Fallback: scan descendants for likely nape/neck parts (case-insensitive)
        for _, desc in ipairs(titan:GetDescendants()) do
            if desc and desc.Parent and desc:IsA("BasePart") then
                local lname = desc.Name:lower()
                if lname == "nape" or lname:find("nape") or lname:find("neck") then
                    found = desc
                    break
                end
            end
        end
    end)

    if found then
        napeCache[titan] = found
    end
    return found
end

local function applyHitboxSize(nape, sizeX, sizeY, sizeZ)
    if not nape or not nape.Parent then return end
    pcall(function()
        nape.Size = Vector3.new(sizeX, sizeY, sizeZ)
        nape.CanCollide = true
    end)
end

local function modifyNapeHitbox(titan)
    if not titan or not titan.Parent then return false end
    if modifiedTitans[titan] then return false end

    local humanoid = titan:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end

    local nape = getNape(titan)
    if not nape then return false end

    pcall(function()
        modifiedTitans[titan] = true
        originalSizes[titan] = nape.Size
        log("Registered: " .. titan.Name, "NAPE")
        debugNotify("Registered: " .. titan.Name, "Info")

        if UI.GetValue("hitbox_enabled") then
            applyHitboxSize(nape, lastHitboxSize.x, lastHitboxSize.y, lastHitboxSize.z)
        end

        titan.Destroying:Once(function()
            modifiedTitans[titan] = nil
            originalSizes[titan] = nil
        end)
    end)

    return true
end

local function create3DBox()
    if not Drawing_new then return {} end
    local lines = {}
    local r = (UI and UI.GetValue and UI.GetValue("esp_color_r")) or 0
    local g = (UI and UI.GetValue and UI.GetValue("esp_color_g")) or 255
    local b = (UI and UI.GetValue and UI.GetValue("esp_color_b")) or 0
    local thickness = (UI and UI.GetValue and UI.GetValue("esp_thickness")) or 2

    for i = 1, 12 do
        local ok, line = pcall(Drawing_new, "Line")
        if ok and line then
            pcall(function()
                line.Color = Color3_fromRGB(r, g, b)
                line.Thickness = thickness
                line.Visible = false
            end)
            lines[i] = line
        end
    end
    return lines
end

local function drawBox(lines, nape, espEnabled, r, g, b, thickness)
    if not lines or not nape or not nape.Parent then return end
    pcall(function()
        local pos = nape.Position
        local size = nape.Size
        if not pos or not size then return end

        local corners = getCorners(pos, size)
        if #corners == 0 then return end

        local projected = {}
        for i, corner in ipairs(corners) do
            projected[i] = worldToScreen(corner)
        end

        for i, edge in ipairs(BOX_EDGES) do
            local p1 = projected[edge[1]]
            local p2 = projected[edge[2]]
            local line = lines[i]
            if not line then continue end

            if p1 and p2 then
                if r and g and b then pcall(function() line.Color = Color3_fromRGB(r, g, b) end) end
                if thickness then pcall(function() line.Thickness = thickness end) end
                line.From = Vector2_new(p1.X, p1.Y)
                line.To = Vector2_new(p2.X, p2.Y)
                line.Visible = espEnabled
            else
                pcall(function() line.Visible = false end)
            end
        end
    end)
end

local function createESP(titan)
    if not titan or not titan.Parent then return end
    if titanESP[titan] then return end

    local lines = create3DBox()
    if not lines or #lines == 0 then return end

    titanESP[titan] = { model = titan, lines = lines }
end

local function removeESP(titan)
    local data = titanESP[titan]
    if not data or not data.lines then return end
    for _, line in ipairs(data.lines) do
        if line then pcall(function() line:Remove() end) end
    end
    titanESP[titan] = nil
end

local function cleanupESP()
    for titan, data in pairs(titanESP) do
        if not data or not data.model then removeESP(titan); continue end

        if not titan or not titan.Parent then removeESP(titan); continue end

        pcall(function()
            local humanoid = titan:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health <= 0 then
                removeESP(titan)
                return
            end

            local nape = getNape(titan)
            if not nape or not nape.Parent then
                removeESP(titan)
            end
        end)
    end
end

local function updateTitans()
    cleanupESP()

    local espEnabled = true
    local r, g, b, thickness = nil, nil, nil, nil
    local ok1, v1 = pcall(function() return UI.GetValue("esp_enabled") end)
    if ok1 then espEnabled = v1 end
    if espEnabled then
        local ok_r, rr = pcall(function() return UI.GetValue("esp_color_r") end)
        local ok_g, gg = pcall(function() return UI.GetValue("esp_color_g") end)
        local ok_b, bb = pcall(function() return UI.GetValue("esp_color_b") end)
        local ok_t, tt = pcall(function() return UI.GetValue("esp_thickness") end)
        r = ok_r and rr or 0
        g = ok_g and gg or 255
        b = ok_b and bb or 0
        thickness = ok_t and tt or 2
    end

    if not espEnabled then
        -- Hide existing ESP lines when ESP is turned off
        for titan, data in pairs(titanESP) do
            if data and data.lines then
                for _, line in ipairs(data.lines) do
                    if line then pcall(function() line.Visible = false end) end
                end
            end
        end
        return
    end

    for titan, data in pairs(titanESP) do
        if not data or not data.model or not data.lines then continue end
        pcall(function()
            if titan and titan.Parent then
                local nape = getNape(titan)
                if nape and nape.Parent then
                    drawBox(data.lines, nape, espEnabled, r, g, b, thickness)
                end
            end
        end)
    end
end

local function updateModifiedTitans()
    local sizeX = UI.GetValue("hitbox_size_x") or 400
    local sizeY = UI.GetValue("hitbox_size_y") or 500
    local sizeZ = UI.GetValue("hitbox_size_z") or 400
    lastHitboxSize.x = sizeX
    lastHitboxSize.y = sizeY
    lastHitboxSize.z = sizeZ

    local targets = {}
    for titan, _ in pairs(modifiedTitans) do targets[titan] = true end
    for titan, _ in pairs(allTitans) do targets[titan] = true end

    for titan, _ in pairs(targets) do
        pcall(function()
            if titan and titan.Parent then
                local humanoid = titan:FindFirstChildOfClass("Humanoid")
                if not humanoid or humanoid.Health <= 0 then
                    allTitans[titan] = nil
                    modifiedTitans[titan] = nil
                    originalSizes[titan] = nil
                    autofarmTitans[titan] = nil
                    return
                end

                local nape = getNape(titan)
                if nape and nape.Parent then
                    if autofarmTitans[titan] then return end
                    if UI.GetValue("hitbox_enabled") then
                        applyHitboxSize(nape, sizeX, sizeY, sizeZ)
                    else
                        local orig = originalSizes[titan]
                        if orig then
                            pcall(function()
                                nape.Size = orig
                            end)
                        end
                    end
                end
            else
                allTitans[titan] = nil
                modifiedTitans[titan] = nil
                originalSizes[titan] = nil
                autofarmTitans[titan] = nil
            end
        end)
    end
end

local function initialize()
    log("Initializing Hitbox Extender + ESP...", "INIT")

    if not Workspace then
        log("Workspace not available!", "ERROR")
        return
    end

    titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then
        titansFolder = Workspace:WaitForChild("Titans", CONFIG.maxWaitTime)
    end

    if not titansFolder then
        log("Titans folder not found!", "ERROR")
        debugNotify("Titans folder not found", "Error")
        return
    end

    local function processTitan(titan)
        if not titan or not titan.Parent then return end
        allTitans[titan] = true
        modifyNapeHitbox(titan)
        createESP(titan)

        pcall(function()
            titan.Destroying:Once(function()
                allTitans[titan] = nil
                modifiedTitans[titan] = nil
            end)
        end)
    end

    pcall(function()
        for _, titan in ipairs(titansFolder:GetChildren()) do
            processTitan(titan)
        end
    end)

    pcall(function()
        titansFolder.ChildAdded:Connect(processTitan)
    end)

    log("Initialization complete!", "INIT")
    notify("Hitbox Extender + ESP Ready", "Success", 3)
end

