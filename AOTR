local function isTitanDead(titan)
    if not titan then return true end
    if not titan.Parent then return true end
    if killedTitans[titan] then return true end
    local ok, dead = pcall(function() return titan:GetAttribute("Dead") end)
    if ok and dead == true then
        killedTitans[titan] = osClock()
        return true
    end
    if not titan:FindFirstChildOfClass("Humanoid") then
        killedTitans[titan] = osClock()
        return true
    end
    return false
end

local function isNearDeathZone(pos)
    local children = titansFolder and titansFolder:GetChildren() or {}
    for i = 1, #children do
        local titan = children[i]
        if titan and titan.Parent then
            local hb = titan:FindFirstChild("Hitboxes")
            if hb then
                local detect = hb:FindFirstChild("Detect")
                if detect then
                    local death = detect:FindFirstChild("Death")
                    if death and death.Parent then
                        local ok, dist = pcall(function() return magnitude(pos - death.Position) end)
                        if ok and dist < DEATH_ZONE_DISTANCE then
                            return true
                        end
                    end
                end
            end
        end
    end
    return false
end

local function getTitanBobHeight(titan)
    if not titan then return BOB_HEIGHT_NORMAL end
    if titan.Name == "Attack_Titan" then return BOB_HEIGHT_ATTACK end
    local ok, t = pcall(function() return titan:GetAttribute("Type") end)
    if ok and (t == "Colossal" or t == "Stall") then return BOB_HEIGHT_STALL end
    return BOB_HEIGHT_NORMAL
end

local function isInLoadingPeriod()
    return (osClock() - sessionStartTime) < INITIAL_LOAD_TIME
end

local function getDistanceToTitan(titan)
    local hrp = getHRP()
    if not hrp then return 99999 end
    local thrp = getTitanHRP(titan)
    if thrp then
        local ok, dist = pcall(function() return magnitude(thrp.Position - hrp.Position) end)
        return ok and dist or 99999
    end
    local nape = getNapeFast(titan)
    if nape and isValidPart(nape) then
        local ok, dist = pcall(function() return magnitude(nape.Position - hrp.Position) end)
        return ok and dist or 99999
    end
    return 99999
end

local function _getTitanPositionXZ(titan)
    local thrp = getTitanHRP(titan)
    if thrp then return thrp.Position end
    local head = getTitanHead(titan)
    if head then return head.Position end
    local nape = getNapeFast(titan)
    return (nape and isValidPart(nape)) and nape.Position or nil
end

local function _anyTitansExist()
